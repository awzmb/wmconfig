{
  "ignition": {
    "version": "3.5.0"
  },
  "passwd": {
    "users": [
      {
        "name": "core",
        "sshAuthorizedKeys": [
          "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIFlWNFIAoXzlQRhLVB/5RwUIikiHuefpPchd0ePb5tCM",
          "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIADD4LxwIuay/NAuqHkr+tlXzQLJbj9BgQGeSjo5ju7h"
        ]
      }
    ]
  },
  "storage": {
    "directories": [
      {
        "path": "/etc/wolf",
        "mode": 493
      }
    ],
    "files": [
      {
        "overwrite": true,
        "path": "/etc/hostname",
        "contents": {
          "compression": "",
          "source": "data:,bincus"
        },
        "mode": 420
      },
      {
        "overwrite": true,
        "path": "/etc/modules-load.d/kubernetes.conf",
        "contents": {
          "compression": "",
          "source": "data:,overlay%0Abr_netfilter%0A"
        },
        "mode": 420
      },
      {
        "overwrite": true,
        "path": "/etc/sysconfig/ovn",
        "contents": {
          "compression": "",
          "source": "data:,OVN_NORTHD_OPTS%3D%22%22%0AOVN_CONTROLLER_OPTS%3D%22%22%0A"
        },
        "mode": 420
      },
      {
        "path": "/etc/sysctl.d/11-max-map-count.conf",
        "contents": {
          "compression": "",
          "source": "data:,vm.max_map_count%20%3D%202147483642%0A"
        },
        "mode": 420
      },
      {
        "path": "/etc/subuid",
        "append": [
          {
            "compression": "",
            "source": "data:,root%3A1065536%3A65536%0A"
          }
        ]
      },
      {
        "path": "/etc/subgid",
        "append": [
          {
            "compression": "",
            "source": "data:,root%3A1065536%3A65536%0A"
          }
        ]
      },
      {
        "path": "/usr/local/bin/install-packages.sh",
        "contents": {
          "compression": "gzip",
          "source": "data:;base64,"
        },
        "mode": 493
      },
      {
        "path": "/usr/local/bin/install-minio.sh",
        "contents": {
          "compression": "gzip",
          "source": "data:;base64,"
        },
        "mode": 493
      },
      {
        "path": "/usr/local/bin/install-minio-client.sh",
        "contents": {
          "compression": "gzip",
          "source": "data:;base64,"
        },
        "mode": 493
      },
      {
        "path": "/etc/incus/pre-seed.yaml",
        "contents": {
          "compression": "gzip",
          "source": "data:;base64,"
        }
      },
      {
        "path": "/etc/udev/rules.d/85-wolf-virtual-inputs.rules",
        "contents": {
          "compression": "gzip",
          "source": "data:;base64,"
        },
        "mode": 420
      },
      {
        "path": "/etc/containers/systemd/wolf.container",
        "contents": {
          "compression": "gzip",
          "source": "data:;base64,"
        },
        "mode": 420
      }
    ]
  },
  "systemd": {
    "units": [
      {
        "contents": "[Unit]\nDescription=Install packages on first boot\nWants=network-online.target\nAfter=network-online.target\n# This service only runs once\nConditionPathExists=!/var/lib/%N.stamp\n\n[Service]\nType=oneshot\n# Create a lock file to prevent this service from running again\nExecStart=/usr/local/bin/install-packages.sh\nExecStart=/bin/touch /var/lib/%N.stamp\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "install-packages.service"
      },
      {
        "contents": "[Unit]\nDescription=Layer minio with rpm-ostree\nWants=network-online.target\nAfter=network-online.target\nAfter=install-packages.service\nBefore=zincati.service\n# This service only runs once\nConditionPathExists=!/var/lib/%N.stamp\n\n[Service]\nType=oneshot\nExecStart=/usr/local/bin/install-minio-client.sh\nExecStart=/usr/local/bin/install-minio.sh\nExecStart=/bin/touch /var/lib/%N.stamp\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "install-minio.service"
      },
      {
        "contents": "[Unit]\nDescription=Disable SELinux on first boot\n# This service should run on first boot to set the kernel arguments.\n# The change will be effective on the next reboot, which is triggered\n# by the GPU driver installation service.\nConditionPathExists=!/var/lib/selinux-disabled.stamp\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\n# Set the kernel argument to disable SELinux\nExecStart=/usr/bin/rpm-ostree kargs --append=selinux=0\n# Create a stamp file to prevent this service from running again\nExecStartPost=/usr/bin/touch /var/lib/selinux-disabled.stamp\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "disable-selinux.service"
      }
    ]
  }
}
