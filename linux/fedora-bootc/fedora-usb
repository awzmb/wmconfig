#!/usr/bin/env bash
#
# fedora-usb
#
# Turn a built Fedora bootc image into a bootable LIVE INSTALLER ISO and
# (optionally) flash it to a USB stick.
#
# The ISO is built with tacklebox (tuna-os/tacklebox): it packs the flavor image
# into a squashfs live environment (its own systemd-boot + `tbox-live` initramfs
# modules — our image's grub2 only matters for the INSTALLED system, not the live
# media) and embeds the same image as an offline payload for `bootc install`. The
# live env autologins root on tty1 and runs the installer (flavors/base/live/
# install.sh): partition -> LUKS2 -> `bootc install to-filesystem` -> BLS unlock
# karg. This REPLACES the old bib/Anaconda `anaconda-iso` path (flavors/base/bib/).
#
# CREDIT: the live-ISO pipeline is built on tuna-os/tacklebox and the
# tunaOS/fisherman install recipe (Apache-2.0). See flavors/base/live/*.sh.
#
# Runs as root: tacklebox needs a privileged container and root's podman storage,
# and flashing writes a raw device. Build the image rootful too so it lands in the
# store tacklebox reads: `sudo ./fedora-build <flavor>` (avoids a save|load copy).
#
# Usage:
#   sudo ./fedora-usb [options] [flavor]
#
# Options:
#   --image <ref>     image to build from (default: localhost/fedora-<flavor>:latest)
#   --output <dir>    output directory (default: ./target)
#   --device <dev>    USB block device to flash, e.g. /dev/sdb (DESTRUCTIVE)
#   --tacklebox <ref> tacklebox image (default: ghcr.io/tuna-os/tacklebox:latest)
#   --xz              also produce a compressed .iso.xz
#   --yes             skip the flashing confirmation prompt
#   -h, --help        show this help
#
# Examples:
#   sudo ./fedora-usb                     # build gnome-sway live installer ISO into ./target
#   sudo ./fedora-usb --device /dev/sdb   # build ISO and flash to /dev/sdb
#   sudo ./fedora-usb kde                 # kde flavor
#   # fastest (no image copy): sudo ./fedora-build kde && sudo ./fedora-usb kde
set -euo pipefail

self_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
flavorsdir="$self_dir/flavors"
livedir="$flavorsdir/base/live"
PODMAN=${PODMAN:-podman}

die() { printf '\e[1;31m==> error:\e[0m %s\n' "$*" >&2; exit 1; }
info() { printf '\e[1;32m==>\e[0m\e[1m %s\e[0m\n' "$*"; }
warn() { printf '\e[1;33m==> warning:\e[0m %s\n' "$*" >&2; }

# --- defaults ------------------------------------------------------------
image=
outdir="$self_dir/target"
device=
tacklebox_image=${FEDORA_TACKLEBOX:-ghcr.io/tuna-os/tacklebox:latest}
assume_yes=0
want_xz=0
flavor=

# --- parse args ----------------------------------------------------------
while [[ $# -gt 0 ]]; do
	case "$1" in
		--image)     image=$2; shift 2;;
		--output)    outdir=$2; shift 2;;
		--device)    device=$2; shift 2;;
		--tacklebox) tacklebox_image=$2; shift 2;;
		--xz)        want_xz=1; shift;;
		--yes|-y)    assume_yes=1; shift;;
		-h|--help)   sed -n '2,40p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'; exit 0;;
		-*)          die "unknown option: $1";;
		*)           flavor=$1; shift;;
	esac
done

flavor=${flavor:-gnome-sway}
flavordir="$flavorsdir/$flavor"
[[ -d $flavordir ]] || die "flavor '$flavor' not found in $flavorsdir"
[[ -f $livedir/install.sh && -f $livedir/customize-live.sh ]] \
	|| die "live installer scripts missing under $livedir"

image=${image:-localhost/fedora-${flavor}:latest}

# desktop hint for the tacklebox recipe (cosmetic here — we boot to a TTY
# installer, not a desktop — but the recipe schema expects it).
case "$flavor" in
	kde) desktop=kde;;
	*)   desktop=gnome;;
esac

command -v "$PODMAN" >/dev/null 2>&1 || die "$PODMAN not found"
[[ $(id -u) -eq 0 ]] || die "must run as root (tacklebox needs a privileged container): sudo ./fedora-usb ${*:-}"

outdir=$(mkdir -p "$outdir" && realpath -- "$outdir")

# --- ensure the image is in ROOT's podman storage ------------------------
# tacklebox (rootful) reads root's storage, which is separate from a rootless
# `./fedora-build`. Fast path: `sudo ./fedora-build` already put it there.
root_id=$("$PODMAN" image inspect --format '{{.Id}}' "$image" 2>/dev/null || true)
user_id=""
if [[ -n ${SUDO_USER:-} ]]; then
	user_id=$(sudo -u "$SUDO_USER" podman image inspect --format '{{.Id}}' "$image" 2>/dev/null || true)
fi
if [[ -n $user_id && $user_id != "$root_id" ]]; then
	info "syncing image from ${SUDO_USER}'s storage to root; tip: 'sudo ./fedora-build $flavor' avoids this copy"
	sudo -u "$SUDO_USER" podman image save "$image" | "$PODMAN" image load \
		|| die "transfer failed — build the image first with: ./fedora-build $flavor"
elif [[ -n $root_id ]]; then
	info "using image already in root storage (${root_id:0:12})"
else
	die "image '$image' not found in root or ${SUDO_USER:-local} podman storage; build it first (fastest: sudo ./fedora-build $flavor)"
fi

# --- assemble a tacklebox build dir (recipe + live scripts side by side) --
# live_customize paths in the recipe are relative to the recipe file, so the
# scripts must sit next to it.
label=$(printf 'FEDORA-%s' "$flavor" | tr '[:lower:]' '[:upper:]')
build=$(mktemp -d "$outdir/.tacklebox-XXXXXX")
trap 'rm -rf "$build"' EXIT
cp "$livedir/install.sh" "$livedir/customize-live.sh" "$build/"

cat > "$build/recipe.json" <<EOF
{
  "media_name": "$label",
  "size": "16G",
  "shared_store": { "format": "ext4" },
  "kargs": ["console=tty0"],
  "bootable_environments": [
    {
      "id": "fedora-$flavor",
      "image": "$image",
      "title": "Fedora $flavor installer (live)",
      "desktop": "$desktop",
      "modes": ["live"],
      "live_customize": ["customize-live.sh"]
    }
  ],
  "offline_payloads": ["$image"]
}
EOF

# --- run tacklebox -------------------------------------------------------
iso="$outdir/fedora-$flavor.iso"
info "building live installer ISO with tacklebox ($tacklebox_image)"
"$PODMAN" run --rm --privileged --pull=newer \
	-v /dev:/dev \
	-v /var/lib/containers:/var/lib/containers \
	-v "$build":/work -w /work \
	"$tacklebox_image" \
	build /work/recipe.json --iso /work/out.iso -b /work/build --verbose $([[ $want_xz -eq 1 ]] && echo --xz) --yes

[[ -f $build/out.iso ]] || die "tacklebox did not produce an ISO"
mv -f "$build/out.iso" "$iso"
[[ $want_xz -eq 1 && -f $build/out.iso.xz ]] && mv -f "$build/out.iso.xz" "$iso.xz"
info "artifact: $iso"

# --- optionally flash to USB --------------------------------------------
if [[ -z $device ]]; then
	cat <<EOF

No --device given, so nothing was flashed.

To write the installer to a USB stick manually:
  sudo dd if='$iso' of=/dev/sdX bs=4M status=progress oflag=direct conv=fsync
  sync

(Replace /dev/sdX with your USB device. Double-check with 'lsblk' first!)
EOF
	exit 0
fi

[[ -b $device ]] || die "$device is not a block device"
if findmnt -rno SOURCE,TARGET | grep -q "^${device}.* / *$"; then
	die "$device hosts the running root filesystem; refusing to flash"
fi
if lsblk -rno MOUNTPOINT "$device" 2>/dev/null | grep -q '^/$'; then
	die "$device appears to be mounted at /; refusing to flash"
fi

echo
warn "About to OVERWRITE all data on $device:"
lsblk -o NAME,SIZE,TYPE,MODEL,MOUNTPOINTS "$device" || lsblk "$device"
echo
if [[ $assume_yes -ne 1 ]]; then
	read -r -p "Type 'YES' to write '$(basename "$iso")' to $device: " ans
	[[ $ans == YES ]] || die "aborted by user"
fi

for part in $(lsblk -rno NAME "$device" | tail -n +2); do
	umount "/dev/$part" 2>/dev/null || true
done

info "writing to $device ..."
dd if="$iso" of="$device" bs=4M status=progress oflag=direct conv=fsync
sync
info "done; $device is now a bootable Fedora live installer"
