# Containerfile — the shared BASE bootc image (localhost/fedora-base).
#
# This is the DE-agnostic foundation every flavor builds FROM. `./fedora-build`
# builds this first, then the selected flavor layers its desktop on top.
# Everything the base needs lives next to this file:
#
#   package.list         dnf packages to layer (system/dev/gaming/virt/CLI/...)
#   package-remove.list  packages to remove
#   flatpak.list         flatpaks installed on first boot
#   overlay/             rootfs overlay (/etc, /usr config, services, helpers)
#   scripts/setup-repos.sh   add RPM Fusion + Tailscale
#   scripts/configure.sh     services, timezone, locale, plymouth, initramfs, ...
#   bib/config.toml      bootc-image-builder config (used by ./fedora-usb)
#
# Base: a standard Fedora bootc image. Override with `--build-arg BASE=<ref>`
# (./fedora-build passes FEDORA_BASE through for you).
ARG BASE=quay.io/fedora/fedora-bootc:rawhide
FROM ${BASE}

# Everything happens in ONE layer, and the build context is bind-mounted (never
# COPY'd into a layer), so no build-only cruft — dnf caches, logs, the variant
# dir — is ever baked into the image. Deleting files in a *later* layer does NOT
# reclaim their space, so setup + install + overlay + configure + cleanup must
# share a single RUN.
#
# --setopt=install_weak_deps=False drops "recommended" (but non-essential)
# packages, the single biggest size lever for a dnf image. The critical
# drivers/firmware/mesa/portals are all listed explicitly in package.list, so
# nothing needed is lost. --skip-unavailable/--skip-broken keep the build
# resilient to packages with no Fedora equivalent for a given release.
RUN --mount=type=bind,source=.,target=/run/fedora/variant \
    set -eu; \
    HB=/run/fedora/variant; export HB; \
    bash "$HB/scripts/setup-repos.sh"; \
    pkgs=$(sed -e 's/#.*//' "$HB/package.list" | tr -s ' \t' '\n' | awk 'NF'); \
    if [ -n "$pkgs" ]; then \
        dnf -y install --setopt=install_weak_deps=False \
            --skip-unavailable --skip-broken $pkgs; \
    fi; \
    cp -a "$HB/overlay/." / 2>/dev/null || true; \
    mkdir -p /usr/share/fedora; cp -f "$HB/flatpak.list" /usr/share/fedora/ 2>/dev/null || true; \
    chmod -R a+rx /usr/libexec/fedora-* 2>/dev/null || true; \
    bash "$HB/scripts/configure.sh"; \
    dnf clean all; \
    rm -rf /var/cache/* /var/lib/dnf/history* /var/log/* /tmp/* /var/tmp/* 2>/dev/null || true

# bootc images must pass the container lint.
RUN bootc container lint
