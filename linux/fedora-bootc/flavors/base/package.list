# Fedora package list for the shared BASE image (flavors/base).
#
# This is the DE-agnostic foundation shared by every flavor: system, dev,
# gaming, virt, CLI, networking, media — but NOT the desktop environment, its
# display manager or its portals (those live in flavors/<desktop>/package.list).
# Installed with `dnf install` inside the bootc image build.
#
# Lines beginning with '#' and blank lines are ignored. Packages that have no
# Fedora equivalent or are Arch/arkdep specific are commented out with a note.
# RPM Fusion + Tailscale are wired up in scripts/setup-repos.sh.

# Basic packages
# apparmor # Fedora uses SELinux by default; kept off
bind-utils
binutils
btrfs-progs
cryptsetup # LUKS management (luksChangeKey, luksAddKey, etc.)
systemd-cryptsetup # /usr/lib/systemd/systemd-cryptsetup + @.service — REQUIRED to unlock the encrypted root at boot; split out of systemd, absent from the minimal bootc base, so the initramfs's `systemctl start systemd-cryptsetup@luks-…` fails without it
debugedit
diffutils
distrobox
dosfstools
e2fsprogs # mkfs.ext4 — the live installer (live/install.sh) formats /boot ext4; usually in the bootc base but pinned so the live env always has it
efibootmgr
espeak-ng
f2fs-tools
fakeroot
git
# Locale data. The base is a STANDARD Fedora bootc image whose glibc matches the
# Fedora repos, so the langpack installs normally (the old distroless `.hum1`
# glibc that forced a localedef workaround is gone). glibc-langpack-en ships the
# en_US.UTF-8 locale; glibc-locale-source ships the i18n source files so
# `localedef` still works as a fallback in configure.sh.
glibc-langpack-en
glibc-locale-source
iproute # ip, ss (socket stats) — likely in base, pinned explicitly
iptables-nft # iptables/ebtables on the nftables backend
lvm2
man-db
mesa-dri-drivers
mesa-va-drivers
mesa-vulkan-drivers
xorg-x11-server-Xwayland # X11 apps under Wayland; a Recommends, so weak-deps-off drops it — every flavor's compositor (GNOME/Sway/Hyprland/Plasma) needs it
neovim
NetworkManager
openssh-clients
orca
plymouth
# Boot-splash plugin + default Fedora theme (bgrt). Without a theme package
# plymouth has nothing to render; the initramfs is regenerated with the plymouth
# dracut module and `rhgb quiet` kargs are set in post_install.sh.
plymouth-plugin-label
plymouth-theme-spinner
pv
qemu-guest-agent
alsa-sof-firmware
# Bare-metal devices need GPU and Wi-Fi firmware; the distroless base does not
# ship it. In current Fedora `linux-firmware` was split into per-vendor
# subpackages and no longer bundles iwlwifi / GPU blobs, so request them
# explicitly. intel-gpu-firmware ships the i915/xe GuC+HuC blobs the GPU driver
# loads after pivot (see dracut.conf.d/fedora.conf on why we don't force GPU
# drivers into the initramfs).
# Also inherited by the Anaconda installer image so the live installer has Wi-Fi.
linux-firmware
iwlwifi-mvm-firmware
iwlwifi-dvm-firmware
intel-gpu-firmware
amd-gpu-firmware
# Non-Intel Wi-Fi/BT vendors: linux-firmware no longer bundles these either, so
# an adapter from any of these vendors shows up with no firmware (and often no
# driver at all — see kernel-modules-extra below) without them explicitly listed.
realtek-firmware
atheros-firmware
brcmfmac-firmware
mediatek-firmware
mt7xxx-firmware
libertas-firmware
# Some Wi-Fi drivers (e.g. rtw88/rtw89, mt76, ath9k_htc) ship in the "extra"
# kernel-modules split, not the base kernel package pulled in by the bootc base
# image — without it the adapter has no firmware AND no driver, so it never
# shows up as a network device at all.
kernel-modules-extra
sudo
terminus-fonts
terminus-fonts-console
tpm2-tools
tpm2-tss
vulkan-tools
vulkan-loader
wget2
xfsprogs
zsh

# Audio
realtime-setup # Fedora equivalent of realtime-privileges

# Container
podman
podman-compose
containernetworking-plugins
crun
virtiofsd
# Isolated containers with unikernel (microvm)
crun-krun
krunvm

# Virtualization (KVM / libvirt) — enough to create and run KVM guests with
# virt-manager / virt-install / virsh. libvirt-daemon-kvm pulls qemu-kvm and all
# the daemon drivers; virt-install pulls libvirt-client. So no separate `libvirt`
# meta or `libvirt-client` needed.
libvirt-daemon-kvm
libvirt-daemon-config-network # default NAT 'default' network
libvirt-nss
qemu-img # create/convert VM disks (qcow2/raw)
virt-install
virt-manager
virt-viewer
edk2-ovmf # UEFI (OVMF) firmware for guests
swtpm # software TPM for guests (Windows 11 etc.)
swtpm-tools

# Object storage / system containers
# Classic LXC system containers.
lxc
lxc-templates

# NOTE: the desktop environment (GNOME / Sway / Hyprland / KDE), its display
# manager and portals are NOT in this base list — each flavor layer adds them.
# This base image is the shared, DE-agnostic foundation (system, dev, gaming,
# virt, CLI, networking, media). See ../gnome-sway, ../gnome, ../kde.

# Desktop (DE-agnostic bits: audio, bluetooth, flatpak, portals frontend, ...)
bluez
bluez-tools
flatpak
flatpak-builder
fuse
fuse3
fwupd
gstreamer1-plugins-base
gstreamer1-plugins-good
gstreamer1-plugins-bad-free
gstreamer1-plugins-ugly-free # RPM Fusion
gstreamer1-plugin-libav # RPM Fusion
libde265 # RPM Fusion
ibus-typing-booster
pipewire
pipewire-alsa
pipewire-jack-audio-connection-kit
pipewire-pulseaudio
power-profiles-daemon
spice-vdagent
switcheroo-control
webp-pixbuf-loader
wireplumber
xdg-user-dirs
xdg-utils
xdg-desktop-portal # base portal frontend (backends are per-flavor)

# Hardware / microcode
microcode_ctl # covers intel + amd ucode on Fedora

# Shell and tools
keyd
sshuttle
fzf
tmux
vim-enhanced
foot
vifm
gh
git-delta
git-lfs
git-crypt
pass
oath-toolkit
w3m
calc
eza
bat
fd-find
yarnpkg
htop
mpv
calcurse
yamllint
glow
unrar
wireguard-tools
python3
python-unversioned-command
python3-pip
pipx
python3-neovim
nmap-ncat
termshark
zip
ctags
cscope
ttyd
broot
glances
procs
yq
age
uv

# Development
luarocks
rust-analyzer
cargo

# Basic system tools
lsof
less
file
which
strace
util-linux                     # lscpu, lsblk, dmesg, mount, etc.

# Rust CLI tools (preferred over the traditional equivalents where a Fedora
# package exists; the classics come from the base coreutils/util-linux anyway).
#   already listed above: eza (ls), bat (cat), fd-find (find), git-delta (diff),
#   procs (ps), broot (tree/nav)
ripgrep                        # grep
sd                             # sed (find/replace)
du-dust                        # du
bottom                         # top/htop (provides `btm`)
zoxide                         # cd (smart jump)
zellij                         # tmux-style terminal multiplexer
tealdeer                       # tldr (fast man summaries; provides `tldr`)
gitui                          # git terminal UI
hyperfine                      # command benchmarking (time)
bandwhich                      # per-process network bandwidth monitor

# Media drivers and extensions
intel-media-driver
libva-intel-driver
intel-compute-runtime
intel-gpu-tools
intel-graphics-compiler
intel-gmmlib
libva-utils
radeontop
nvtop
mesa-libGL
mesa-libEGL

# General desktop packages (DE-agnostic: terminals, fonts, applets)
miller
alacritty
brightnessctl
blueman
wl-clipboard                   # generic Wayland clipboard CLI
NetworkManager-applet
pavucontrol
pass-otp
fontconfig
fontawesome-fonts-all
kitty
google-noto-emoji-fonts

# Themes and icons
papirus-icon-theme
gnome-themes-extra

# Gaming (RPM Fusion + Flathub)
steam                          # RPM Fusion (nonfree)
gamemode
lutris
mangohud
# moonlight-qt                 # Flatpak (see flatpak.list)

# Camera
v4l-utils
# v4l2loopback-dkms / -utils   # akmod-v4l2loopback via RPM Fusion
akmod-v4l2loopback             # RPM Fusion
libcamera
libcamera-tools
pipewire-plugin-libcamera
obs-studio                     # RPM Fusion

# Networking
opensnitch
NetworkManager-vpnc
NetworkManager-openconnect
NetworkManager-openvpn
xmlstarlet                     # i hate cisco with a passion
nftables
tcpdump
iputils
traceroute
mtr
whois
tailscale                      # mesh VPN (repo added in scripts/setup-repos.sh)

# Bare-metal / image-mode tooling
coreos-installer
bootc
jq
yq

# Secure Boot: the signed shim is what makes the image bootable with Secure Boot
# enabled (shim -> grub2 -> kernel, all signed by Fedora's keys). The base usually
# ships it, but pin it so the guarantee does not depend on the base. Enabling
# Secure Boot itself is a UEFI firmware action, not a build step.
shim-x64
grub2-efi-x64
