# Containerfile — the gnome flavor (GNOME only).
#
# Layers a plain GNOME desktop on top of the shared base image
# (localhost/fedora-base). ./fedora-build builds the base first and passes it as
# --build-arg BASE. Repos come from the base image; this layer only adds the
# GNOME packages and enablement.
ARG BASE=localhost/fedora-base:latest
FROM ${BASE}

# Single layer, bind-mounted context (see flavors/base/Containerfile). No overlay
# dir for this flavor, so the cp is a no-op tolerated by `|| true`.
ARG CACHEBUST
RUN --mount=type=bind,source=.,target=/run/fedora/variant \
    set -eu; \
    : "cachebust ${CACHEBUST:-}"; \
    HB=/run/fedora/variant; export HB; \
    pkgs=$(sed -e 's/#.*//' "$HB/package.list" | tr -s ' \t' '\n' | awk 'NF'); \
    if [ -n "$pkgs" ]; then \
        dnf -y install --setopt=install_weak_deps=False \
            --skip-unavailable --skip-broken $pkgs; \
    fi; \
    cp -a "$HB/overlay/." / 2>/dev/null || true; \
    bash "$HB/scripts/configure.sh"; \
    dnf clean all; \
    rm -rf /var/cache/* /var/lib/dnf/history* /var/log/* /tmp/* /var/tmp/* 2>/dev/null || true

RUN bootc container lint
