# Containerfile — the gnome-sway flavor (GNOME + Sway + Hyprland).
#
# Layers the desktop on top of the shared base image (localhost/fedora-base).
# ./fedora-build builds the base first and passes it as --build-arg BASE.
# The base already carries the Fedora/RPM Fusion/Tailscale repos, so this layer
# only adds the desktop packages, overlay and enablement.
#
#   package.list         desktop packages (GNOME shell, GDM, Sway, Hyprland, ...)
#   overlay/             desktop overlay (seatd, portals, suspend hook)
#   scripts/configure.sh GDM + Sway default session + seat/suspend services
ARG BASE=localhost/fedora-base:latest
FROM ${BASE}

# One layer, bind-mounted context (see flavors/base/Containerfile for why): the
# desktop packages, overlay, configure and cleanup all share a single RUN so no
# dnf cache / log / build-context cruft is baked into the image. Weak deps are
# dropped (--setopt=install_weak_deps=False); the base already carries the repos.
RUN --mount=type=bind,source=.,target=/run/fedora/variant \
    set -eu; \
    HB=/run/fedora/variant; export HB; \
    pkgs=$(sed -e 's/#.*//' "$HB/package.list" | tr -s ' \t' '\n' | awk 'NF'); \
    if [ -n "$pkgs" ]; then \
        dnf -y install --setopt=install_weak_deps=False \
            --skip-unavailable --skip-broken $pkgs; \
    fi; \
    cp -a "$HB/overlay/." / 2>/dev/null || true; \
    chmod -R a+rx /usr/local/bin 2>/dev/null || true; \
    bash "$HB/scripts/configure.sh"; \
    dnf clean all; \
    rm -rf /var/cache/* /var/lib/dnf/history* /var/log/* /tmp/* /var/tmp/* 2>/dev/null || true

# bootc images must pass the container lint.
RUN bootc container lint
