#!/usr/bin/env bash
#
# hummingbird-build
#
# Build a Fedora Hummingbird (bootc / image-mode) OS image from a declarative
# variant configuration, in the spirit of `arkdep-build`.
#
# Where arkdep-build pacstraps a root and chroots into it, this renders a
# Containerfile from the variant and builds it with podman/buildah. The variant
# layout mirrors arkdep-build.d:
#
#   hummingbird-build.d/<variant>/
#     type                 -> must contain `fedora`
#     name.sh              -> (optional) sourced, output used as image name
#     base.list            -> base image used as FROM (arkdep `bootstrap.list`)
#     package.list         -> dnf packages to layer
#     package-remove.list  -> packages to remove
#     copr.list            -> COPR repos to enable
#     flatpak.list         -> flatpaks installed on first boot
#     python-tools.list    -> uv tools installed on first login
#     overlay/post_bootstrap, overlay/post_install  -> rootfs overlays
#     extensions/{pre_build,post_bootstrap,post_install,post_build}.sh
#     bib/config.toml      -> bootc-image-builder config (used by hummingbird-usb)
#
# Usage:
#   ./hummingbird-build [variant]
#
# Environment overrides:
#   HUMMINGBIRD_BASE   override the base image (FROM) from base.list
#   HUMMINGBIRD_TAG    override the built image tag (default localhost/<variant>:latest)
#   PODMAN             podman binary to use (default: podman)
#   KEEP_CONTEXT=1     keep the temporary build context for inspection
#
set -euo pipefail

self_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
configsdir="$self_dir/hummingbird-build.d"
PODMAN=${PODMAN:-podman}

die() { printf '\e[1;31m==> error:\e[0m %s\n' "$*" >&2; exit 1; }
info() { printf '\e[1;32m==>\e[0m\e[1m %s\e[0m\n' "$*"; }

variant=${1:-awzm-hummingbird}
variantdir="$configsdir/$variant"

[[ -d $variantdir ]] || die "variant '$variant' not found in $configsdir"
command -v "$PODMAN" >/dev/null 2>&1 || die "$PODMAN not found; install podman/buildah"

# --- type check ----------------------------------------------------------
type_file="$variantdir/type"
[[ -f $type_file ]] || die "missing $type_file"
read -r build_type < "$type_file"
[[ $build_type == fedora ]] || die "unsupported type '$build_type' (this builder only handles 'fedora')"

# --- base image (FROM) ---------------------------------------------------
if [[ -n ${HUMMINGBIRD_BASE:-} ]]; then
	base_image=$HUMMINGBIRD_BASE
else
	[[ -f $variantdir/base.list ]] || die "missing base.list and HUMMINGBIRD_BASE unset"
	base_image=$(grep -vE '^\s*#|^\s*$' "$variantdir/base.list" | head -n1 | xargs)
fi
[[ -n $base_image ]] || die "could not determine base image"

# --- image name ----------------------------------------------------------
if [[ -n ${HUMMINGBIRD_TAG:-} ]]; then
	image_tag=$HUMMINGBIRD_TAG
else
	image_name=$variant
	[[ -f $variantdir/name.sh ]] && image_name=$(bash "$variantdir/name.sh")
	image_tag="localhost/${image_name}:latest"
fi

# --- release version (dnf releasever) ------------------------------------
# Hummingbird is a rolling, rawhide-based distribution. We always build against
# Fedora rawhide so layered packages match the base and stay current; there is
# intentionally no option to pin a numbered release. The numeric rawhide version
# (needed for GPG key filenames) is detected dynamically inside the build.
releasever=rawhide

info "variant      : $variant"
info "base image   : $base_image"
info "target image : $image_tag"
info "releasever   : $releasever"

# --- assemble build context ---------------------------------------------
context=$(mktemp -d /tmp/hummingbird-build.XXXXXX)
cleanup() { [[ ${KEEP_CONTEXT:-0} == 1 ]] || rm -rf "$context"; }
trap cleanup EXIT

cp -a "$variantdir" "$context/variant"

# Pre-compute the cleaned dnf package list (strip comments + blanks).
pkgfile="$context/variant/packages.txt"
if [[ -f $variantdir/package.list ]]; then
	sed -e 's/#.*//' "$variantdir/package.list" | awk 'NF' | tr -s ' \t' '\n' | awk 'NF' \
		> "$pkgfile"
fi
pkg_count=$(wc -l < "$pkgfile" 2>/dev/null || echo 0)
info "packages to install: $pkg_count"

# Ensure overlay dirs exist so cp never fails.
mkdir -p "$context/variant/overlay/post_bootstrap" "$context/variant/overlay/post_install"

# --- generate Containerfile ---------------------------------------------
cat > "$context/Containerfile" <<EOF
# Generated by hummingbird-build for variant: $variant
FROM $base_image

# Make the variant configuration available during the build only.
COPY variant /run/hummingbird/variant
ENV HUMMINGBIRD_VARIANT_DIR=/run/hummingbird/variant

# pre_build: add Fedora repos (the Hummingbird base ships only its own curated
# repo) plus RPM Fusion + COPR, before installing packages.
RUN bash /run/hummingbird/variant/extensions/pre_build.sh

# Apply the post_bootstrap overlay (early /etc, /usr config).
RUN cp -a /run/hummingbird/variant/overlay/post_bootstrap/. / 2>/dev/null || true

# post_bootstrap hook.
RUN bash /run/hummingbird/variant/extensions/post_bootstrap.sh

# Install layered packages. --skip-unavailable/--skip-broken keep the build
# resilient to packages that have no Fedora equivalent for a given release.
RUN if [ -s /run/hummingbird/variant/packages.txt ]; then \\
        dnf -y install --skip-unavailable --skip-broken \$(cat /run/hummingbird/variant/packages.txt) ; \\
    fi && dnf clean all

# Apply the post_install overlay (services, helper scripts).
RUN cp -a /run/hummingbird/variant/overlay/post_install/. / 2>/dev/null || true

# Ship list metadata consumed by the first-boot/first-login units.
RUN mkdir -p /usr/share/hummingbird && \\
    for f in flatpak.list python-tools.list ; do \\
        [ -f /run/hummingbird/variant/\$f ] && cp -f /run/hummingbird/variant/\$f /usr/share/hummingbird/ || true ; \\
    done

# Make shipped helper scripts executable.
RUN chmod -R a+rx /usr/libexec/hummingbird-* /usr/local/bin 2>/dev/null || true

# post_install hook (services, timezone, package removals, dconf).
RUN bash /run/hummingbird/variant/extensions/post_install.sh

# Remove build-only material so it does not ship in the image.
RUN rm -rf /run/hummingbird /var/cache/* /var/lib/dnf/history* /var/log/* 2>/dev/null || true

# bootc images must pass the container lint.
RUN bootc container lint
EOF

info "generated Containerfile:"
sed 's/^/    /' "$context/Containerfile"

# --- build ---------------------------------------------------------------
info "building image (this can take a while)..."
"$PODMAN" build --pull=newer -t "$image_tag" -f "$context/Containerfile" "$context"

# Also tag a stable, predictable reference for downstream tooling.
stable_tag="localhost/${variant}:latest"
"$PODMAN" tag "$image_tag" "$stable_tag" || true

# --- post_build hook -----------------------------------------------------
if [[ -x $variantdir/extensions/post_build.sh || -f $variantdir/extensions/post_build.sh ]]; then
	HUMMINGBIRD_IMAGE=$image_tag HUMMINGBIRD_VARIANT=$variant \
		bash "$variantdir/extensions/post_build.sh" || true
fi

info "done"
info "built: $image_tag"
info "alias: $stable_tag"
cat <<EOF

Next steps:
  * Test locally:     sudo $PODMAN run --rm -it $image_tag /bin/bash
  * Build a USB/ISO:  sudo ./hummingbird-usb $variant
  * Push to registry: $PODMAN push $image_tag <registry>/<repo>:<tag>
EOF
