# Fedora package list for the awzm-hummingbird variant.
#
# Ported from arkane/arkdep-build.d/awzmlinux/package.list (Arch) to Fedora/dnf
# package names. Installed with `dnf install` inside the bootc image build.
#
# Lines beginning with '#' and blank lines are ignored. Packages that have no
# Fedora equivalent, are Arch/arkdep specific, or live in COPR/RPM Fusion are
# commented out with a note (COPR repos -> copr.list, RPM Fusion -> see build).

# Basic packages
# apparmor                    # Fedora uses SELinux by default; kept off
bind-utils
binutils
btrfs-progs
debugedit
diffutils
distrobox
dosfstools
efibootmgr
espeak-ng
f2fs-tools
fakeroot
git
glibc-langpack-en
lvm2
man-db
mesa-dri-drivers
mesa-va-drivers
mesa-vulkan-drivers
neovim
NetworkManager
openssh-clients
openssh-server
orca
plymouth
pv
qemu-guest-agent
alsa-sof-firmware
sudo
terminus-fonts
terminus-fonts-console
tpm2-tools
tpm2-tss
vulkan-tools
vulkan-loader
wget2
xfsprogs
zsh
# kmscon                      # COPR (see copr.list)
# arch-install-scripts        # Arch-only
# archiso                     # Arch-only
# arkdep                      # replaced by bootc
# skel-arkane                 # Arch/arkane-only
# libnss-extrausers           # not needed under bootc (standard nsswitch)
# sudo-rs                     # not packaged; using sudo
# pacman-contrib              # Arch-only

# Audio
realtime-setup                # Fedora equivalent of realtime-privileges

