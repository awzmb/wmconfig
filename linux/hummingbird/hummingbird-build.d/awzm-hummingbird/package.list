# Fedora package list for the awzm-hummingbird variant.
#
# Ported from arkane/arkdep-build.d/awzmlinux/package.list (Arch) to Fedora/dnf
# package names. Installed with `dnf install` inside the bootc image build.
#
# Lines beginning with '#' and blank lines are ignored. Packages that have no
# Fedora equivalent, are Arch/arkdep specific, or live in COPR/RPM Fusion are
# commented out with a note (COPR repos -> copr.list, RPM Fusion -> see build).

# Basic packages
# apparmor                    # Fedora uses SELinux by default; kept off
bind-utils
binutils
btrfs-progs
cryptsetup                    # LUKS management (luksChangeKey, luksAddKey, etc.)
debugedit
diffutils
distrobox
dosfstools
efibootmgr
espeak-ng
f2fs-tools
fakeroot
git
# glibc-langpack-en omitted: it hard-pins `glibc = <exact EVR>` and the distroless
# base ships a `.hum1` glibc no Fedora langpack matches, so it is always dropped by
# --skip-broken. post_install.sh generates en_US.UTF-8 with `localedef` instead.
iproute                       # ip, ss (socket stats) — likely in base, pinned explicitly
iptables-nft                  # iptables/ebtables on the nftables backend
lvm2
man-db
mesa-dri-drivers
mesa-va-drivers
mesa-vulkan-drivers
neovim
NetworkManager
openssh-clients
openssh-server
orca
plymouth
# Boot-splash plugin + default Fedora theme (bgrt). Without a theme package
# plymouth has nothing to render; the initramfs is regenerated with the plymouth
# dracut module and `rhgb quiet` kargs are set in post_install.sh.
plymouth-plugin-label
plymouth-theme-spinner
pv
qemu-guest-agent
alsa-sof-firmware
# Bare-metal devices need GPU and Wi-Fi firmware; the distroless base does not
# ship it. In current Fedora `linux-firmware` was split into per-vendor
# subpackages and no longer bundles iwlwifi / GPU blobs, so request them
# explicitly (these pair with the i915/xe/amdgpu drivers forced in dracut).
# Also inherited by the Anaconda installer image so the live installer has Wi-Fi.
linux-firmware
iwlwifi-mvm-firmware
iwlwifi-dvm-firmware
intel-gpu-firmware
amd-gpu-firmware
sudo
terminus-fonts
terminus-fonts-console
tpm2-tools
tpm2-tss
vulkan-tools
vulkan-loader
wget2
xfsprogs
zsh

# Audio
realtime-setup                # Fedora equivalent of realtime-privileges

# Container
podman
podman-compose
containernetworking-plugins
crun
virtiofsd

# Virtualization (KVM / libvirt) — enough to create and run KVM guests with
# virt-manager / virt-install / virsh. libvirt-daemon-kvm pulls qemu-kvm and all
# the daemon drivers; virt-install pulls libvirt-client. So no separate `libvirt`
# meta or `libvirt-client` needed.
libvirt-daemon-kvm
libvirt-daemon-config-network  # default NAT 'default' network
libvirt-nss
qemu-img                       # create/convert VM disks (qcow2/raw)
virt-install
virt-manager
virt-viewer
edk2-ovmf                      # UEFI (OVMF) firmware for guests
swtpm                          # software TPM for guests (Windows 11 etc.)
swtpm-tools

# Object storage / system containers
# Classic LXC system containers.
lxc
lxc-templates
# minio-client                # COPR / upstream binary (see copr.list)

# GNOME (GDM login/greeter; Sway is the default session — see post_install.sh.
# gnome-shell is required by the GDM greeter even though Sway is the main WM)
gdm
evolution-data-server
gnome-backgrounds
gnome-console
gnome-control-center
gnome-disk-utility
gnome-initial-setup
gnome-menus
gnome-shell
gnome-software
gnome-system-monitor
gnome-tweaks
gnome-keyring
mutter
nautilus
gvfs
gvfs-afc
gvfs-fuse
gvfs-goa
gvfs-gphoto2
gvfs-mtp
gvfs-nfs
gvfs-smb
xdg-desktop-portal-gnome

