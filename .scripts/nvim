#!/bin/bash

IMAGE_NAME="localhost/neovim:latest"
USERNAME=$(whoami)
USER_ID=$(id -u)
GROUP_ID=$(id -g)

# The main run command
# NOTE: this assumes that the host is using Wayland for wl-clipboard support
#
# No persistent home volume: config, plugins, Mason tools and the
# cargo/rustup toolchain are all baked into the image, and /home/${USERNAME}
# is the container's own writable layer (owned by the build UID, which maps
# to your user via --userns=keep-id), so nvim can write ~/.local/state etc.
# Your actual work persists via the /workspace bind mount.
#
# Want shada/undo history to survive `--rm`? Add ONLY a state volume (it
# holds no baked content, so nothing is hidden and no seeding is needed):
#   --volume neovim_state:/home/${USERNAME}/.local/state:U,Z \
podman run --rm -it \
  --group-add keep-groups \
  --userns=keep-id \
  --env WAYLAND_DISPLAY \
  --env XDG_RUNTIME_DIR \
  --env XDG_SESSION_TYPE=wayland \
  --volume "${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}:${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}:Z" \
  --user "${USER_ID}:${GROUP_ID}" \
  --volume "${PWD}:/workspace:Z" \
  --workdir /workspace \
  "${IMAGE_NAME}" "$@"
