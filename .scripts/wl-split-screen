#!/bin/bash

# --- Configuration ---
output_json=$(swaymsg -t get_outputs | jq -r '.[] | select(.focused)')

PHYSICAL_OUTPUT=$(echo "$output_json" | jq -r '.name')
WIDTH=$(echo "$output_json" | jq -r '.current_mode.width')
HEIGHT=$(echo "$output_json" | jq -r '.current_mode.height')

# --- Logic ---
if pgrep -x "wl-mirror" > /dev/null
then
    echo "wl-mirror is already running. Exiting."
    # To stop the existing screens, you can run: killall wl-mirror
    exit 0
fi

# Check if we successfully got the output details
if [ -z "$PHYSICAL_OUTPUT" ] || [ -z "$WIDTH" ] || [ -z "$HEIGHT" ]; then
    echo "Error: Could not determine focused output's dimensions."
    exit 1
fi

HALF_WIDTH=$((WIDTH / 2))

echo "Physical screen: $PHYSICAL_OUTPUT (${WIDTH}x${HEIGHT})"
echo "Splitting into two virtual screens of ${HALF_WIDTH}x${HEIGHT} each."

# Create Left Virtual Screen
# The format is X,Y,WIDTH,HEIGHT
wl-mirror --region "0,0,${HALF_WIDTH},${HEIGHT}" --virtual "VIRTUAL-LEFT" "$PHYSICAL_OUTPUT" &

# Create Right Virtual Screen
wl-mirror --region "${HALF_WIDTH},0,${HALF_WIDTH},${HEIGHT}" --virtual "VIRTUAL-RIGHT" "$PHYSICAL_OUTPUT" &

echo "Ultrawide screen split into VIRTUAL-LEFT and VIRTUAL-RIGHT."
echo "To stop, run: killall wl-mirror"
