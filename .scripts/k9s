#!/bin/sh

podman run --rm -it \
  --user "$(id -u):$(id -g)" \
  --userns=keep-id \
  --volume "$HOME/.config/gcloud:/home/$(whoami)/.config/gcloud:Z" \
  --volume "$HOME/.kube:/home/$(whoami)/.kube:ro" \
  --volume "$HOME/.config/k9s:/home/$(whoami)/.config/k9s:Z" \
  --volume "$(pwd):/workspace" \
  --volume "${HOME}/.docker/config.json:/home/$(whoami)/.docker/config.json:ro" \
  --workdir "/workspace" \
  --env=KUBECONFIG=/home/$(whoami)/.kube/config \
  --env=TERM=$(echo ${TERM}) \
  --env=EDITOR=nvim \
  localhost/gcloud-k9s:latest "$@"
