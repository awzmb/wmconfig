#!/bin/bash

# --- Configuration ---
# Name of the workspace that will host the mirrors
HOST_WORKSPACE="Monitor-Host"

# --- Cleanup Existing Setup ---
if pgrep -x "wl-mirror" > /dev/null; then
    echo "Stopping existing split setup..."
    killall wl-mirror

    # Destroy previously created headless outputs
    for out in $(swaymsg -t get_outputs | jq -r '.[] | select(.name | startswith("HEADLESS")) | .name'); do
        swaymsg output "$out" unplug
    done
    exit 0
fi

# --- Get Physical Output Info ---
output_json=$(swaymsg -t get_outputs | jq -r '.[] | select(.focused)')
PHYSICAL_OUTPUT=$(echo "$output_json" | jq -r '.name')
WIDTH=$(echo "$output_json" | jq -r '.current_mode.width')
HEIGHT=$(echo "$output_json" | jq -r '.current_mode.height')

if [ -z "$PHYSICAL_OUTPUT" ] || [ -z "$WIDTH" ] || [ -z "$HEIGHT" ]; then
    echo "Error: Could not determine focused output's dimensions."
    exit 1
fi

HALF_WIDTH=$((WIDTH / 2))

echo "Physical screen: $PHYSICAL_OUTPUT (${WIDTH}x${HEIGHT})"
echo "Creating two virtual screens of ${HALF_WIDTH}x${HEIGHT} each."

# --- 1. Create Headless Outputs ---
swaymsg create_output
swaymsg create_output

# Fetch their dynamically generated names (usually HEADLESS-1 and HEADLESS-2)
HEADLESS1=$(swaymsg -t get_outputs | jq -r '.[] | select(.name | startswith("HEADLESS")) | .name' | sed -n '1p')
HEADLESS2=$(swaymsg -t get_outputs | jq -r '.[] | select(.name | startswith("HEADLESS")) | .name' | sed -n '2p')

# --- 2. Configure Headless Outputs ---
# Set their resolution to exactly half of your physical monitor
swaymsg output "$HEADLESS1" resolution "${HALF_WIDTH}x${HEIGHT}"
swaymsg output "$HEADLESS2" resolution "${HALF_WIDTH}x${HEIGHT}"

# Position them side-by-side so your mouse moves smoothly between them
swaymsg output "$HEADLESS1" pos 0 0
swaymsg output "$HEADLESS2" pos "$HALF_WIDTH" 0

# Move the physical monitor far away logically, so your mouse doesn't accidentally enter the host workspace
swaymsg output "$PHYSICAL_OUTPUT" pos 0 5000

# --- 3. Setup the Physical Host Workspace ---
# Switch to physical monitor and setup the host workspace
swaymsg workspace "$HOST_WORKSPACE"
swaymsg move workspace to output "$PHYSICAL_OUTPUT"

# Ensure the layout is a horizontal split
swaymsg layout splith

# --- 4. Launch Mirrors ---
# Display HEADLESS1 on the left
wl-mirror "$HEADLESS1" &
sleep 0.5 # Give it a moment to map

# Display HEADLESS2 on the right
wl-mirror "$HEADLESS2" &
sleep 0.5

# --- 5. Remove borders and gaps for a seamless look ---
swaymsg "[app_id=\"wl-mirror\"] border none"
swaymsg workspace "$HOST_WORKSPACE" gaps inner 0
swaymsg workspace "$HOST_WORKSPACE" gaps outer 0

# --- 6. Assign Workspaces to the Virtual Monitors ---
# Assign Workspace 1 to the Left split and Workspace 2 to the Right split
swaymsg workspace 1 output "$HEADLESS1"
swaymsg workspace 2 output "$HEADLESS2"

# Finally, move your focus inside the left split so you can start opening apps
swaymsg workspace 1
